<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="SecurePassGen"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="Per-monitor"/>
        <ExecutionLevel Value="highestAvailable"/>
        <TextName Value="KoaSoft.Sec.SecurePassGen"/>
        <TextDesc Value="SecurePassGen is a lightweight and user-friendly desktop application developed with Lazarus (Free Pascal) for generating secure, customizable passwords.

The application allows users to create strong passwords based on selected character types, including uppercase letters, lowercase letters, numbers, and symbols. It ensures enhanced security by generating passwords with unique characters (no repetition), reducing predictability and improving strength.

With an intuitive interface, users can easily adjust password length using a slider and instantly generate a password. The generated password is automatically copied to the clipboard for quick use and can also be saved in a local history log for future reference."/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <MajorVersionNr Value="2"/>
      <MinorVersionNr Value="3"/>
      <Language Value="040C"/>
      <Attributes pvaDebug="True"/>
      <StringTable CompanyName="KoaSoft" FileDescription="The application allows users to create strong passwords based on selected character types" LegalCopyright="© 2026" OriginalFilename="Secure Password Generator"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="SecurePassGen.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="mainform.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FormMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="MainForm"/>
      </Unit>
      <Unit>
        <Filename Value="unitabout.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FormAbout"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="UnitAbout"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="SecurePassGen"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
